<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Bt.Runtime\Bt.Runtime.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\examples\move-safe-pos.tree.json" Link="move-safe-pos.tree.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net6.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Workaround for MSBuild GenerateDepsFile failing to load System.Text.Json in some VS/MSBuild environments -->
    <GenerateDependencyFile>false</GenerateDependencyFile>
  </PropertyGroup>

</Project>
